{{ 'component-upsell-products.css' | asset_url | stylesheet_tag }}
{%- if block.settings.title -%}
  <h2 class="product-block-title font-body mb-8">{{ block.settings.title }}</h2>
{%- endif -%}
<aside class="upsell-products grid grid-cols-1" style="--gap: 8px;">
  {%- for upsell_product in block.settings.upsell_products -%}
    {%- render 'card-product-upsell',
      product: upsell_product,
      product_form_id: product_form_id,
      is_preorder: is_preorder,
      block: block,
      section: section
    -%}
  {%- endfor -%}
</aside>