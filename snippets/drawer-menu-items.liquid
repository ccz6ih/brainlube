{%- liquid
  # Set class names based on current level
  # - link classes applied to the link or button element
  assign panel_class_name = ''
  case current_level
    when 1
      assign link_classes = 'menu-link'
      assign panel_class_name = 'drawer-submenu__panel'
    when 2
      assign link_classes = 'sub-menu-link'
      assign panel_class_name = 'drawer-subsubmenu__panel'
    when 3
      assign link_classes = 'sub-sub-menu-link size--small'
  endcase

  # Format base variables
  assign menu_item_title = menu_item.title | remove: '|||' | strip
  assign has_content = false

  # Handle menu item styles
  if menu_item_title contains ':::'
    assign menu_item_split = menu_item_title | split: ':::'
    assign menu_item_title = menu_item_split[0] | strip
    assign menu_item_style = menu_item_split[1] | handleize | prepend: ' style--badge-'
    assign link_classes = link_classes | append: menu_item_style
  elsif menu_item_title contains '***'
    assign menu_item_title = menu_item_title | remove: '***' | strip
    assign link_classes = link_classes | append: ' style--emphasize'
  endif

  # Check if menu item has content
  if content_menu_titles contains menu_item_title
    assign has_content = true
  endif

  # Find megamenu block for menu item
  assign megamenu_match_title = menu_item_title
  assign megamenu_block = nil
  if has_content
    for block in section.blocks
      unless block.type contains 'megamenu-'
        continue
      endunless
      if block.settings.menu_parent == megamenu_match_title
        assign megamenu_block = block
        break
      endif
    endfor
  endif
-%}

{% if menu_item.title contains '---' %}
  <hr class="drawer-menu-divider"/>
{% else %}
  {% if menu_item.levels == 0 and has_content == false %}

    {%- comment -%} Direct Link, menu item has no children {%- endcomment -%}
    {% capture link_content %}
      <a href="{{ menu_item.url }}" class="{{ link_classes }}" aria-label="{{ 'accessibility.navigate_to_something' | t: something: menu_item_title }}" title="{{ 'accessibility.navigate_to_something' | t: something: menu_item_title }}">
        <span>{{ menu_item_title }}</span>
      </a>
    {% endcapture %}

    {%- comment -%} Wrap in a drawer-menu-item container for level 1 {%- endcomment -%}
    {% if current_level == 1 %}
      <div class="drawer-menu-item {%- if hide_on_desktop %} medium-up--hide{% endif %}">
        {{ link_content }}
      </div>
    {% else %}
      {{ link_content }}
    {% endif %}

  {% else %}

    {%- liquid
      assign new_current_level = current_level | plus: 1
      capture drawer_content
        for sublink in menu_item.links
          render 'drawer-menu-items', menu_item: sublink, current_level: new_current_level, context: context, section: section
        endfor
      endcapture
    -%}

    {%- if current_level == 1 -%}
      {%- comment -%} Accordion Link, menu item has children {%- endcomment -%}
      {%- assign panel_id = 'panel-' | append: menu_scope | append: '-' | append: menu_item.handle | append: '-' | append: context | handleize -%}
      {%- if context == 'no-js' -%}
        <details class="{{ link_classes }} --drilldown drawer-menu__details {%- if hide_on_desktop %} medium-up--hide{% endif %}" data-accordion-item data-submenu-id="{{ panel_id }}">
          <summary class="{{ link_classes }}" aria-label="{{ 'accessibility.view_something_menu' | t: something: menu_item_title }}">
            <span>{{ menu_item_title | strip }}</span>
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-chevron-right"><polyline points="9 18 15 12 9 6"/></svg>
          </summary>
      {%- else -%}
        <div class="drawer-menu-item --drilldown {%- if hide_on_desktop %} medium-up--hide{% endif %}" data-accordion-item data-submenu-id="{{ panel_id }}">
          <button
            type="button"
            class="drawer-menu-button {{ link_classes }}"
            aria-expanded="false"
            aria-controls="{{ panel_id | append: '-container' }}"
            aria-label="{{ 'accessibility.view_something_menu' | t: something: menu_item_title }}"
            data-drawer-submenu-trigger
          >
            <span>{{ menu_item_title | strip }}</span>
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-chevron-right"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
      {%- endif -%}

        <div id="{{ panel_id | append: '-container' }}" data-accordion-panel class="{{ panel_class_name | append: '-container' }} {{ context }} {% if has_content %} --content{% endif %}">
          <div class="{{ panel_class_name }}">

            {% if current_level == 1 and context == 'js' %}
              <header class="drawer-header">
                {%- comment -%} Submenu Panel - Go back to main level {%- endcomment -%}
                <button class="close--submenu" title="{{ 'accessibility.hide_something_menu' | t: something: menu_item_title }}" aria-label="{{ 'accessibility.hide_something_menu' | t: something: menu_item_title }}" type="button" data-drawer-submenu-close="{{ panel_id }}">
                  <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-chevron-left"><polyline points="15 18 9 12 15 6"/></svg>
                </button>

                <span class="text-align-center">{{ menu_item_title }}</span>

                {%- comment -%} Submenu Panel - Close navigation {%- endcomment -%}
                <a class="close medium-up--hide" role="button" href="#" aria-label="{{ 'accessibility.close_navigation' | t }}" class="close" data-drawer-close data-close>{%- render 'icon-close' -%}</a>
              </header>
            {% endif %}

            <div class="drawer-content scrollbar--hide">
              {%- if has_content and megamenu_block -%}
                <div class="megamenu-panel">
                  {% render 'megamenu', block: megamenu_block, menu_item: menu_item, context: 'drawer', section: section %}
                </div>
              {%- elsif has_content -%}
                <div class="megamenu-panel">
                  {{ drawer_content }}
                </div>
              {%- else -%}
                {{ drawer_content }}
              {%- endif -%}
            </div>

          </div>
        </div>
      {%- if context == 'no-js' -%}
        </details>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <a href="{{ menu_item.url }}" class="{{ link_classes }}" aria-label="{{ 'accessibility.navigate_to_something' | t: something: menu_item_title }}" title="{{ 'accessibility.navigate_to_something' | t: something: menu_item_title }}">
        <span>{{ menu_item_title }}</span>
      </a>
      <div class="sub-sub-menu mb-16">
        {{ drawer_content }}
      </div>
    {%- endif -%}
  {% endif %}

{% endif %}