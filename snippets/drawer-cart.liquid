<drawer-cart id="drawer-cart" data-id="{{ section.id }}" class="drawer drawer--wide main-cart" data-drawer data-parent style="opacity: 0; display: none;">
  <div class="drawer-panel user-select-none slide-from-right color-{{ settings.color_scheme_drawers }}" data-contents>
    <header class="drawer-header">
        <h3 class="size--small" aria-label="{{ 'accessibility.your_cart' | t }}">{{ 'sections.cart.title' | t }}</h3>
        <a role="button" href="#" class="close" data-close aria-label="{{ 'accessibility.close_cart_drawer' | t }}">{%- render 'icon-close' -%}</a>
    </header>

    <div class="drawer-content">
      {%- render 'cart-shipping-notification', cart: cart -%}
      <form id="cart" action="{{ routes.cart_url }}" method="post">
        {%- render 'cart-items' -%}
      </form>
      {%- render 'cart-recommendations', section: section, context: 'drawer' -%}
    </div>

    <footer class="drawer-footer">
      {%- render 'cart-note' -%}
      {%- render 'cart-footer' -%}
    </footer>
  </div>

  {% comment %} Background, click to close {% endcomment %}
  <a href="#" class="page-overlay color-{{ settings.color_scheme_drawers }}" data-overlay tabindex="-1"></a>
</drawer-cart>