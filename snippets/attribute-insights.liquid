{% if value != blank %}
{{ 'component-attribute-insights.css' | asset_url | stylesheet_tag }}
{% assign attribute_insights_value = value | times: 1 %}

<div class="attribute-insights type--{{ type }}" style="--insights-value:{{ attribute_insights_value }}; --border-radius:{{ border_radius | append: 'px' }};">
  {% if attribute_title != blank %}
    <p class="attribute-title">{{ attribute_title }}</p>
  {% endif %}

  {% case type %}
  {% when 'slider' %}
    <div class="scale {%- if show_helper_splitters %} show-splitters {%- endif %}">
      <div class="line"></div>
      {% if show_helper_splitters %}
        <div class="helper-splitter" style="--helper-splitter-position: calc( 1 / 3 * 100%);"></div>
        <div class="helper-splitter" style="--helper-splitter-position: calc( 2 / 3 * 100%);"></div>
      {% endif %}
      <div class="marker"></div>
    </div>
  {% when 'fill' %}
    <div class="fill-bar">
      <div class="fill"></div>
    </div>
  {% when 'segmented' %}
    {% assign segment_size = 100.00 | divided_by: amount_of_segments %}
    <div class="segments">
      {% for i in (1..amount_of_segments) %}
        {% liquid
          assign is_active = false
          assign current_range_start = segment_size | times: forloop.index0
          assign current_range_end = segment_size | times: forloop.index
          if attribute_insights_value > current_range_end or attribute_insights_value > current_range_start and attribute_insights_value <= current_range_end
            assign is_active = true
          endif
        %}
        <div class="segment {%- if is_active %} active {%- endif %}"></div>
      {% endfor %}
    </div>
  {% endcase %}

  <div class="labels size--tiny">
    <span class="label start text-align-left">{{ start_label }}</span>
    <span class="label center text-align-center">{{ center_label }}</span>
    <span class="label end text-align-right">{{ end_label }}</span>
  </div>
</div>

{% if show_messages and attribute_insights_value < below_threshold_value and below_threshold_message != blank %}
  <div class="text--boxed threshold-message-below mt-12">
    <p class="size--small">{{ below_threshold_message }}</p>
  </div>
{% elsif show_messages and attribute_insights_value >= below_threshold_value and attribute_insights_value <= above_threshold_value and between_threshold_message != blank %}
  <div class="text--boxed threshold-message-between mt-12">
    <p class="size--small">{{ between_threshold_message }}</p>
  </div>
{% elsif show_messages and attribute_insights_value > above_threshold_value and above_threshold_message != blank %}
  <div class="text--boxed threshold-message-above mt-12">
    <p class="size--small">{{ above_threshold_message }}</p>
  </div>
{% endif %}

{% endif %}