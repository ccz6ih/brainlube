<div id="{{ section.id }}"
  class="pt pb sm-pt sm-pb container custom-child-for-animation{% if section.settings.enable_full_width %} full-width{% endif %} color-{{ section.settings.color_scheme }}"
  style="
    --pt: {{ section.settings.padding_top | append: 'px' }};
    --pb: {{ section.settings.padding_bottom | append: 'px' }};
    --sm-pt: {{ section.settings.md_padding_top | append: 'px' }};
    --sm-pb: {{ section.settings.md_padding_bottom | append: 'px' }};
  ">

  <div class="grid grid-cols-{{ section.settings.items_per_row_mobile }} sm-grid-cols-{{ section.settings.items_per_row_tablet }} md-grid-cols-{{ section.settings.items_per_row_desktop }} text-align-{{ section.settings.text_align }} sm-text-align-{{ section.settings.sm_text_align }}">
    {% for block in section.blocks %}
    <div {{ block.shopify_attributes }}>
      <a class="{{ section.settings.title_style }} {{ section.settings.size_multiplier }} {{ section.settings.sm_size_multiplier }}" href="#modal-{{ section.id }}?slide={{ forloop.index }}" aria-haspopup="dialog">{{ block.settings.title }}{% if section.settings.show_link_icon %} <span class="link-icon">{% render 'icon-chevron-right' %}</span>{% endif %}</a>
    </div>
    {% endfor %}
  </div>
</div>

{% render 'modal-hotspots-slider', slide_blocks: section.blocks %}

{% schema %}
{
  "name": "t:sections.on-demand-info.name",
  "class": "section--on-demand-info anim-custom-child",
  "disabled_on": {
    "groups": [
      "header",
      "aside"
    ]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.on-demand-info.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "default",
      "label": "t:sections.colors.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "show_link_icon",
      "label": "Show link icon",
      "default": true
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "t:sections.typography.style_options.heading_style_label",
      "default": "subheading flex gap-half-gutter",
      "options": [
        {
          "value": "h3 flex gap-half-gutter",
          "label": "t:sections.typography.style_options.heading",
          "group": "t:sections.typography.style_options.text_group"
        },
        {
          "value": "body-text flex gap-half-gutter",
          "label": "t:sections.typography.style_options.body_text",
          "group": "t:sections.typography.style_options.text_group"
        },
        {
          "value": "subheading flex gap-half-gutter",
          "label": "t:sections.inputs.text.subtitle",
          "group": "t:sections.typography.style_options.text_group"
        },
        {
          "value": "btn btn--primary btn--full",
          "label": "t:sections.typography.style_options.primary_button",
          "group": "t:sections.typography.style_options.button_group"
        },
        {
          "value": "btn btn--secondary btn--full",
          "label": "t:sections.typography.style_options.secondary_button",
          "group": "t:sections.typography.style_options.button_group"
        },
        {
          "value": "btn btn--link btn--full",
          "label": "t:sections.typography.style_options.link",
          "group": "t:sections.typography.style_options.button_group"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.headers.desktop_layout"
    },
    {
      "type": "range",
      "id": "items_per_row_desktop",
      "label": "t:sections.layout.items_per_row",
      "min": 2,
      "max": 6,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "label": "t:sections.layout.section_width.full_width",
      "default": false
    },
    {
      "type": "text_alignment",
      "id": "sm_text_align",
      "label": "t:sections.typography.text_align",
      "default": "center"
    },
    {
      "type": "select",
      "id": "sm_size_multiplier",
      "label": "t:sections.typography.size_options.label",
      "default": "sm-size--default",
      "options": [
        {
          "value": "sm-size--tiny",
          "label": "t:sections.typography.size_options.tiny"
        },
        {
          "value": "sm-size--small",
          "label": "t:sections.typography.size_options.small"
        },
        {
          "value": "sm-size--default",
          "label": "t:sections.typography.size_options.default"
        },
        {
          "value": "sm-size--large",
          "label": "t:sections.typography.size_options.large"
        },
        {
          "value": "sm-size--huge",
          "label": "t:sections.typography.size_options.huge"
        },
        {
          "value": "sm-size--gigantic",
          "label": "t:sections.typography.size_options.gigantic"
        },
        {
          "value": "sm-size--outrageous",
          "label": "t:sections.typography.size_options.outrageous"
        }
      ]
    },
    {
      "type": "range",
      "id": "md_padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "t:sections.layout.margin_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "md_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "t:sections.layout.margin_bottom",
      "default": 40
    },
    {
      "type": "paragraph",
      "content": "t:sections.layout.display_type.tablet_paragraph"
    },
    {
      "type": "range",
      "id": "items_per_row_tablet",
      "label": "t:sections.layout.items_per_row",
      "min": 2,
      "max": 4,
      "default": 4
    },
    {
      "type": "header",
      "content": "t:sections.headers.mobile_layout"
    },
    {
      "type": "text_alignment",
      "id": "text_align",
      "label": "t:sections.typography.text_align",
      "default": "center"
    },
    {
      "type": "select",
      "id": "size_multiplier",
      "label": "t:sections.typography.size_options.label",
      "default": "size--default",
      "options": [
        {
          "value": "size--tiny",
          "label": "t:sections.typography.size_options.tiny"
        },
        {
          "value": "size--small",
          "label": "t:sections.typography.size_options.small"
        },
        {
          "value": "size--default",
          "label": "t:sections.typography.size_options.default"
        },
        {
          "value": "size--large",
          "label": "t:sections.typography.size_options.large"
        },
        {
          "value": "size--huge",
          "label": "t:sections.typography.size_options.huge"
        },
        {
          "value": "size--gigantic",
          "label": "t:sections.typography.size_options.gigantic"
        },
        {
          "value": "size--outrageous",
          "label": "t:sections.typography.size_options.outrageous"
        }
      ]
    },
    {
      "type": "range",
      "id": "items_per_row_mobile",
      "label": "t:sections.layout.items_per_row",
      "min": 1,
      "max": 3,
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "t:sections.layout.margin_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "t:sections.layout.margin_bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "name": "t:sections.on-demand-info.blocks.info-block.name",
      "type": "info_block",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.inputs.text.button_label",
          "default": "Button label"
        },
        {
          "type": "header",
          "content": "t:sections.image-with-hotspots.blocks.hotspot.headers.text_content"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.inputs.text.text",
          "default": "<p>This is the on demand info shown when the Hotspot is clicked.</p>"
        },
        {
          "type": "header",
          "content": "t:sections.image-with-hotspots.blocks.hotspot.headers.media_content"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "t:sections.images.media_type.label",
          "default": "image",
          "options": [
            {
              "value": "image",
              "label": "t:sections.images.media_type.image"
            },
            {
              "value": "video",
              "label": "t:sections.images.media_type.video"
            },
            {
              "value": "external_video",
              "label": "t:sections.images.media_type.external_video"
            },
            {
              "value": "mixed_media",
              "label": "t:sections.images.media_type.mixed_media"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": "t:sections.images.media_type.mixed_media_info",
          "visible_if": "{{ block.settings.media_type == 'mixed_media' }}"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.inputs.image_picker.image",
          "visible_if": "{{ block.settings.media_type == 'image' or block.settings.media_type == 'mixed_media' }}"
        },
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.images.media_type.video",
          "visible_if": "{{ block.settings.media_type == 'video' or block.settings.media_type == 'mixed_media' }}"
        },
        {
          "type": "video_url",
          "id": "external_video_url",
          "label": "t:sections.inputs.url.video_url",
          "info": "t:sections.inputs.url.video_url__info",
          "accept": [
            "youtube",
            "vimeo"
          ],
          "visible_if": "{{ block.settings.media_type == 'external_video' }}"
        },
        {
          "type": "text",
          "id": "external_video_aspect_ratio",
          "label": "t:sections.inputs.external_video_aspect_ratio.label",
          "default": "16:9",
          "visible_if": "{{ block.settings.media_type == 'external_video' }}"
        },
        {
          "type": "checkbox",
          "id": "video_controls",
          "label": "t:sections.images.media_toggle.controls",
          "info": "t:sections.images.media_toggle.controls_info",
          "default": false,
          "visible_if": "{{ block.settings.media_type == 'video' or block.settings.media_type == 'external_video' or block.settings.media_type == 'mixed_media' }}"
        },
        {
          "type": "checkbox",
          "id": "video_autoplay",
          "label": "t:sections.images.media_toggle.autoplay",
          "info": "t:sections.images.media_toggle.autoplay_info",
          "default": true,
          "visible_if": "{{ block.settings.video_controls and block.settings.media_type == 'video' or block.settings.media_type == 'external_video' or block.settings.media_type == 'mixed_media' }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.on-demand-info.name",
      "category": "t:sections.section_categories.utility_and_support",
      "blocks": [
        {
          "type": "info_block"
        },
        {
          "type": "info_block"
        },
        {
          "type": "info_block"
        },
        {
          "type": "info_block"
        }
      ]
    }
  ]
}
{% endschema %}