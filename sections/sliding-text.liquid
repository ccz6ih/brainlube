        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 160,
        "step": 8,
        "unit": "px",
        "label": "t:sections.layout.margin_top",
        "default": 0
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 160,
        "step": 8,
        "unit": "px",
        "label": "t:sections.layout.margin_bottom",
        "default": 24
      }
    ],
    "blocks": [
      {
        "name": "t:sections.blocks.text_and_image.name",
        "type": "text",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "t:sections.inputs.image_picker.image"
          },
          {
            "type": "text",
            "id": "text",
            "label": "t:sections.inputs.text.text",
            "default": "Sliding text"
          },
          {
            "type": "url",
            "id": "link",
            "label": "t:sections.inputs.url.link"
          }
