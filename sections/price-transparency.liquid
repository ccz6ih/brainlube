{% comment %}
 This section is for price transparency purposes.
 - User can select relative or static price calculations and based on this selection blocks will have related settings.
 {% endcomment %}
{{ 'section-price-transparency.css' | asset_url | stylesheet_tag }}
{% liquid
  assign price_components = section.blocks | where: 'type', 'price_component'
  assign total_row_block = section.blocks | where: 'type', 'total_row' | first
  assign content_order = section.settings.content_order

  if section.settings.use_shop_metafield
    assign total_price = shop.metafields.custom.price_transparency_total.value
  else
    assign total_price = section.settings.price_product.price
  endif

  assign grid_class = 'grid-cols-1 sm-grid-cols-2'
  assign max_width_class = 'col-sm-max-6 col-md-max-4'

  capture content_blocks
    render 'content-blocks', blocks: section.blocks, color_scheme: section.settings.color_scheme
  endcapture

  if content_blocks == blank or section.settings.desktop_prices_layout == 'vertical'
    assign grid_class = grid_class | remove: ' sm-grid-cols-2'
  endif

  if section.settings.desktop_prices_layout == 'vertical'
    assign max_width_class = 'col-sm-max-10'
  endif
%}

<div
  id="{{ section.id }}"
  class="container section-spacing {{ content_order }} color-{{ section.settings.color_scheme }} pt pb sm-pt sm-pb"
  style="
    --pt: {{ section.settings.padding_top | append: 'px' }};
    --pb: {{ section.settings.padding_bottom | append: 'px' }};
    --sm-pt: {{ section.settings.md_padding_top | append: 'px' }};
    --sm-pb: {{ section.settings.md_padding_bottom | append: 'px' }};
  "
>
  <div class="grid col-align-items-center col-justify-items-center {{ grid_class }}">
    {% if content_blocks != blank %}
      <div class="content-blocks {{ max_width_class |  replace: 'col-sm-max-10', 'col-sm-max-6 sm-text-align-center' }}">
        {{ content_blocks }}
      </div>
    {% endif %}

    <div class="price-rows-container m-auto {{ max_width_class }} sm-{{ section.settings.desktop_prices_layout }}-price-rows">
      {%- if price_components.size > 0 -%}
        <div class="price-rows">
        {% for price_component in price_components -%}
          {%- assign percentage = price_component.settings.relative_value | divided_by: 100.00 -%}
          {%- assign relative_cost = total_price | times: percentage -%}

          <div class="price-row" {{ price_component.shopify_attributes }}>
            <div class="price-row-icon">
              {% if section.settings.icon_options == 'custom-image' and price_component.settings.image != blank %}
                {{ price_component.settings.image | image_url: width: 100 | image_tag: loading: 'lazy', width: '50', widths: '50, 100' }}
              {% elsif section.settings.icon_options == 'theme-icons'%}
                {% render 'icons', icon_name: price_component.settings.icon %}
              {% endif %}
            </div>
            {% if price_component.settings.text != blank %}
              <div class="price-row-title">
                {{- price_component.settings.text -}}
              </div>
            {% endif %}
            <div class="price-row-value">
              {{- relative_cost | money -}}
            </div>
          </div>
        {%- endfor %}
          {% if section.settings.desktop_prices_layout == 'vertical' and total_row_block != blank %}
            <div class="price-rows-separator"></div>
          {% endif %}
        </div>
      {%- endif -%}

      {%- if total_row_block != blank -%}
        <div class="total-row-container">
          <div class="price-row total-row size--large" {{ total_row_block.shopify_attributes }}>
            <div class="price-row-icon">
              {% if section.settings.icon_options == 'custom-image' and total_row_block.settings.image != blank %}
                {{ total_row_block.settings.image | image_url: width: 100 | image_tag: loading: 'lazy', width: '50', widths: '50, 100' }}
              {% elsif section.settings.icon_options == 'theme-icons' %}
                {% render 'icons', icon_name: total_row_block.settings.icon %}
              {% endif %}
            </div>
          {% if total_row_block.settings.text != blank %}
            <div class="price-row-title">
              {{- total_row_block.settings.text -}}
            </div>
          {% endif %}
            <div class="price-row-value">
              {{- total_price | money -}}
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>
