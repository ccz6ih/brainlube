{% render 'product-template', product: product, section: section %}

{% schema %}
{
  "name": "t:sections.main-product.name",
  "class": "section--main-product ignore-section-animation",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-product.info"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "t:sections.inputs.checkbox.show_breadcrumb",
      "info": "t:sections.inputs.checkbox.show_breadcrumb_info",
      "default": false
    },
    {
      "id": "product_image_aspect_ratio",
      "type": "select",
      "label": "t:sections.main-product.settings.product_image_aspect_ratio.label",
      "options": [
        {
          "value": "natural",
          "label": "t:common.aspect_ratio.value.natural"
        },
        {
          "value": "portrait",
          "label": "t:common.aspect_ratio.value.2_3"
        },
        {
          "value": "portrait_alt",
          "label": "t:common.aspect_ratio.value.3_4"
        },
        {
          "value": "square",
          "label": "t:common.aspect_ratio.value.1_1"
        },
        {
          "value": "landscape",
          "label": "t:common.aspect_ratio.value.4_3"
        }
      ],
      "default": "square"
    },
    {
      "type": "select",
      "id": "media_fill_rule",
      "label": "t:sections.images.fill_rule.label",
      "options": [
        {
          "value": "cover",
          "label": "t:sections.images.fill_rule.cover"
        },
        {
          "value": "contain",
          "label": "t:sections.images.fill_rule.contain"
        }
      ],
      "default": "contain",
      "visible_if": "{{ section.settings.product_image_aspect_ratio != 'natural' }}"
    },
    {
      "type": "select",
      "id": "variant_images",
      "label": "t:sections.main-product.settings.variant_images.label",
      "info": "t:sections.main-product.settings.variant_images.info",
      "default": "all",
      "options": [
        {
          "value": "all",
          "label": "t:sections.main-product.settings.variant_images.options.all"
        },
        {
          "value": "selected",
          "label": "t:sections.main-product.settings.variant_images.options.selected"
        },
        {
          "value": "selected_group",
          "label": "t:sections.main-product.settings.variant_images.options.selected_group"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.main-product.settings.style_header.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "default",
      "label": "t:sections.colors.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "custom_background_colors",
      "label": "t:sections.main-product.settings.custom_background_colors.label",
      "info": "t:sections.main-product.settings.custom_background_colors.info"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "t:sections.main-product.settings.section_bg.label",
      "visible_if": "{{ section.settings.custom_background_colors }}"
    },
    {
      "type": "color_background",
      "id": "media_col_bg",
      "label": "t:sections.main-product.settings.media_col_bg.label",
      "visible_if": "{{ section.settings.custom_background_colors }}"
    },
    {
      "type": "color_background",
      "id": "content_col_bg",
      "label": "t:sections.main-product.settings.content_col_bg.label",
      "visible_if": "{{ section.settings.custom_background_colors }}"
    },
    {
      "id": "border_radius",
      "label": "t:sections.main-product.settings.container_border_radius.label",
      "type": "range",
      "unit": "px",
      "step": 1,
      "min": 0,
      "max": 80,
      "default": 0,
      "visible_if": "{{ section.settings.custom_background_colors }}"
    },
    {
      "type": "color",
      "id": "product_media_bg",
      "label": "t:sections.colors.media_bg.label",
      "default": "transparent",
      "visible_if": "{{ section.settings.custom_background_colors }}"
    },
    {
      "id": "media_border_radius",
      "label": "t:sections.main-product.settings.media_border_radius.label",
      "type": "range",
      "unit": "px",
      "step": 1,
      "min": 0,
      "max": 80,
      "default": 0,
      "visible_if": "{{ section.settings.custom_background_colors }}"
    },
    {
      "type": "header",
      "content": "t:sections.headers.desktop_layout"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main-product.settings.desktop_info.content"
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "label": "t:sections.layout.section_width.full_width",
      "default": true
    },
    {
      "id": "sm-p",
      "label": "t:sections.layout.padding",
      "type": "range",
      "unit": "px",
      "step": 1,
      "min": 0,
      "max": 80,
      "default": 0
    },
    {
      "id": "media_layout",
      "type": "select",
      "label": "t:sections.main-product.settings.media_layout.label",
      "default": "one-column",
      "options": [
        {
          "value": "one-column",
          "label": "t:sections.main-product.settings.media_layout.options.one-column",
          "group": "t:sections.main-product.settings.media_layout.groups.grid"
        },
        {
          "value": "two-columns",
          "label": "t:sections.main-product.settings.media_layout.options.two-columns",
          "group": "t:sections.main-product.settings.media_layout.groups.grid"
        },
        {
          "value": "two-columns-stacked",
          "label": "t:sections.main-product.settings.media_layout.options.two-columns-stacked",
          "group": "t:sections.main-product.settings.media_layout.groups.grid"
        },
        {
          "value": "traditional-below-as-grid",
          "label": "t:sections.main-product.settings.media_layout.options.traditional-below-as-grid",
          "group": "t:sections.main-product.settings.media_layout.groups.traditional"
        },
        {
          "value": "traditional-below",
          "label": "t:sections.main-product.settings.media_layout.options.traditional-below",
          "group": "t:sections.main-product.settings.media_layout.groups.traditional"
        },
        {
          "value": "traditional-next-to",
          "label": "t:sections.main-product.settings.media_layout.options.traditional-next-to",
          "group": "t:sections.main-product.settings.media_layout.groups.traditional"
        },
        {
          "value": "traditional",
          "label": "t:sections.main-product.settings.media_layout.options.traditional-no-thumbnails",
          "group": "t:sections.main-product.settings.media_layout.groups.traditional"
        }
      ]
    },
    {
      "id": "media_col_width",
      "type": "select",
      "label": "t:sections.main-product.settings.media_col_width.label",
      "default": "medium",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.main-product.settings.media_col_width.options.narrow"
        },
        {
          "value": "medium",
          "label": "t:sections.main-product.settings.media_col_width.options.medium"
        },
        {
          "value": "wide",
          "label": "t:sections.main-product.settings.media_col_width.options.wide"
        },
        {
          "value": "extra_wide",
          "label": "t:sections.main-product.settings.media_col_width.options.extra_wide"
        }
      ]
    },
    {
      "type": "select",
      "id": "sm_media_zoom",
      "label": "t:sections.main-product.settings.media_zoom.label",
      "default": "disabled",
      "options": [
        {
          "value": "disabled",
          "label": "t:sections.main-product.settings.media_zoom.options.disabled"
        },
        {
          "value": "column",
          "label": "t:sections.main-product.settings.media_zoom.options.column"
        },
        {
          "value": "slider",
          "label": "t:sections.main-product.settings.media_zoom.options.slider"
        }
      ]
    },
    {
      "id": "sm_media_gap",
      "label": "t:sections.main-product.settings.media_gap.label",
      "type": "range",
      "unit": "px",
      "step": 1,
      "min": 0,
      "max": 40,
      "default": 24
    },
    {
      "type": "range",
      "id": "md_padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "t:sections.layout.margin_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "md_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "t:sections.layout.margin_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.headers.mobile_layout"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main-product.settings.mobile_info.content"
    },
    {
      "type": "checkbox",
      "id": "enable_slider_peek",
      "label": "t:sections.main-product.settings.slider_peek.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_thumbnails_sm_down",
      "label": "t:sections.main-product.settings.show_thumbnails.label",
      "default": false
    },
    {
      "type": "select",
      "id": "media_zoom",
      "label": "t:sections.main-product.settings.media_zoom.label",
      "default": "disabled",
      "options": [
        {
          "value": "disabled",
          "label": "t:sections.main-product.settings.media_zoom.options.disabled"
        },
        {
          "value": "column",
          "label": "t:sections.main-product.settings.media_zoom.options.column"
        },
        {
          "value": "slider",
          "label": "t:sections.main-product.settings.media_zoom.options.slider"
        }
      ]
    },
    {
      "id": "media_gap",
      "label": "t:sections.main-product.settings.media_gap.label",
      "type": "range",
      "unit": "px",
      "step": 1,
      "min": 0,
      "max": 20,
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "t:sections.layout.margin_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "t:sections.layout.margin_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "sibling_products",
      "name": "t:sections.blocks.sibling_products.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.blocks.sibling_products.info"
        },
        {
          "id": "variant_option_name",
          "type": "text",
          "label": "Variant option name",
          "info": "Use variant option name to display a title with variant value."
        },
        {
          "type": "header",
          "content": "t:sections.headers.layout"
        },
        {
          "id": "margin_top",
          "type": "range",
          "label": "t:sections.layout.margin_top",
          "info": "t:sections.blocks.margin_info",
          "unit": "px",
          "default": 8,
          "min": 0,
          "max": 48,
          "step": 4
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.blocks.text.name",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Text block</p>",
          "label": "t:sections.inputs.text.text"
        },
        {
          "type": "checkbox",
          "id": "read_more",
          "label": "t:sections.inputs.text.read_more",
          "info": "t:sections.inputs.text.read_more_info",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "style_boxed",
          "label": "t:sections.blocks.text.style_boxed.label",
          "default": false
        },
        {
          "type": "header",
          "content": "t:sections.headers.layout"
        },
        {
          "id": "margin_top",
          "type": "range",
          "label": "t:sections.layout.margin_top",
          "info": "t:sections.blocks.margin_info",
          "unit": "px",
          "default": 8,
          "min": 0,
          "max": 48,
          "step": 4
        }
      ]
    },
    {
      "type": "title",
      "name": "t:sections.blocks.title.name",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.headers.layout"
        },
        {
          "id": "margin_top",
          "type": "range",
          "label": "t:sections.layout.margin_top",
          "info": "t:sections.blocks.margin_info",
          "unit": "px",
          "default": 8,
          "min": 0,
          "max": 48,
          "step": 4
        }
      ]
    },
    {
      "type": "price",
      "name": "t:sections.blocks.price.name",
      "limit": 1,
      "settings": [
        {
          "id": "margin_top",
          "type": "range",
          "label": "t:sections.layout.margin_top",
          "info": "t:sections.blocks.margin_info",
          "unit": "px",
          "default": 8,
          "min": 0,
          "max": 48,
          "step": 4
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "t:sections.typography.weight_options.label",
          "default": "normal",
          "options": [
            {
              "value": "normal",
              "label": "t:sections.typography.weight_options.normal"
            },
            {
              "value": "bold",
              "label": "t:sections.typography.weight_options.bold"
            }
          ]
        },
        {
          "type": "header",
          "content": "t:sections.headers.desktop_layout"
        },
        {
          "type": "select",
          "id": "sm_size_multiplier",
          "label": "t:sections.typography.size_options.label",
          "default": "sm-size--default",
          "options": [
            {
              "value": "sm-size--tiny",
              "label": "t:sections.typography.size_options.tiny"
            },
            {
              "value": "sm-size--small",
              "label": "t:sections.typography.size_options.small"
            },
            {
              "value": "sm-size--default",
              "label": "t:sections.typography.size_options.default"
            },
            {
              "value": "sm-size--large",
              "label": "t:sections.typography.size_options.large"
            },
            {
              "value": "sm-size--huge",
              "label": "t:sections.typography.size_options.huge"
            },
            {
              "value": "sm-size--gigantic",
              "label": "t:sections.typography.size_options.gigantic"
            },
            {
              "value": "sm-size--outrageous",
              "label": "t:sections.typography.size_options.outrageous"
            }
          ]
        },
        {
          "type": "header",
          "content": "t:sections.headers.mobile_layout"
        },
        {
          "type": "select",
          "id": "size_multiplier",
          "label": "t:sections.typography.size_options.label",
          "default": "size--default",
          "options": [
            {
              "value": "size--tiny",
              "label": "t:sections.typography.size_options.tiny"
            },
            {
              "value": "size--small",
              "label": "t:sections.typography.size_options.small"
            },
            {
              "value": "size--default",
              "label": "t:sections.typography.size_options.default"
            },
            {
              "value": "size--large",
              "label": "t:sections.typography.size_options.large"
            },
            {
              "value": "size--huge",
              "label": "t:sections.typography.size_options.huge"
            },
            {
              "value": "size--gigantic",
              "label": "t:sections.typography.size_options.gigantic"
            },
            {
              "value": "size--outrageous",
              "label": "t:sections.typography.size_options.outrageous"
            }
          ]
        }
      ]
    },
    {
      "type": "quantity_selector",
      "name": "t:sections.blocks.quantity_selector.name",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.headers.layout"
        },
        {
          "type": "checkbox",
          "id": "next_to_add_to_cart",
          "label": "t:sections.blocks.quantity_selector.next_to_add_to_cart.label",
          "default": false
        },
        {
          "id": "margin_top",
          "type": "range",
          "label": "t:sections.layout.margin_top",
          "info": "t:sections.blocks.margin_info",
          "unit": "px",
          "default": 8,
          "min": 0,
          "max": 48,
          "step": 4
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "t:sections.blocks.variant_picker.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "picker_type",
          "options": [
            {
              "value": "dropdown",
              "label": "t:sections.blocks.variant_picker.picker_type.options.dropdown"
            },
            {
              "value": "button",
              "label": "t:sections.blocks.variant_picker.picker_type.options.buttons"
            }
          ],
          "default": "button",
          "label": "t:sections.blocks.variant_picker.picker_type.label"
        },
        {
          "type": "checkbox",
          "id": "cross_out_unavailable",
          "label": "t:sections.blocks.variant_picker.cross_out_unavailable.label",
          "default": true,
          "info": "t:sections.blocks.variant_picker.cross_out_unavailable.info"
        },
        {
          "type": "header",
          "content": "t:sections.headers.layout"
        },
        {
          "id": "margin_top",
          "type": "range",
          "label": "t:sections.layout.margin_top",
          "info": "t:sections.blocks.margin_info",
          "unit": "px",
          "default": 8,
          "min": 0,
          "max": 48,
          "step": 4
        },
        {
          "type": "header",
          "content": "t:sections.blocks.variant_picker.advanced.label",
          "info": "t:sections.blocks.variant_picker.advanced.info"
        },
        {
          "type": "textarea",
          "id": "dropdown_picker_options",
          "label": "t:sections.blocks.variant_picker.dropdown_picker_options.label",
          "info": "t:sections.blocks.variant_picker.dropdown_picker_options.info"
        },
        {
          "type": "textarea",
          "id": "button_picker_options",
          "label": "t:sections.blocks.variant_picker.button_picker_options.label",
          "info": "t:sections.blocks.variant_picker.button_picker_options.info"
        }
      ]
    },
    {
      "type": "size_guide",
      "name": "t:sections.blocks.size_guide.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "size_guide_trigger",
          "label": "t:sections.blocks.size_guide.trigger.label",
          "info": "t:sections.blocks.size_guide.trigger.info",
          "default": "Size"
        },
        {
          "id": "size_guide_button_label",
          "type": "text",
          "label": "t:sections.blocks.size_guide.button_label",
          "default": "Size guide"
        },
        {
          "id": "size_guide_show_ruler",
          "type": "checkbox",
          "label": "t:sections.blocks.size_guide.show_ruler",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "size_guide_image",
          "label": "t:sections.blocks.size_guide.image"
        },
        {
          "type": "richtext",
          "id": "size_guide_content",
          "label": "t:sections.blocks.size_guide.content",
          "default": "<p>Size guide or other useful information about the product</p>"
        },
        {
          "type": "page",
          "id": "size_guide_page_handle",
          "label": "t:sections.blocks.size_guide.page_handle",
          "info": "t:sections.blocks.size_guide.page_handle_info"
        }
      ]
    },
    {
      "type": "inventory_status",
      "name": "t:sections.blocks.inventory_status.name",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "inventory_threshold",
          "label": "t:sections.blocks.inventory_status.inventory_threshold.label",
          "default": 10,
          "min": 0,
          "max": 20,
          "step": 1
        },
        {
          "type": "checkbox",
          "id": "show_available_quantity",
          "label": "t:sections.blocks.inventory_status.show_available_quantity.label",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "inventory_transfers_enable",
          "label": "t:sections.blocks.inventory_status.inventory_transfers_enable.label",
          "info": "t:sections.blocks.inventory_status.inventory_transfers_enable.info",
          "default": true
        },
        {
          "type": "header",
          "content": "t:sections.blocks.inventory_status.additional_descriptions.header"
        },
        {
          "type": "paragraph",
          "content": "t:sections.blocks.inventory_status.additional_descriptions.info_paragraph"
        },
        {
          "type": "text",
          "id": "additional__in_stock",
          "label": "t:sections.blocks.inventory_status.additional_descriptions.text_inputs.additional__in_stock"
        },
        {
          "type": "text",
          "id": "additional__few_on_stock",
          "label": "t:sections.blocks.inventory_status.additional_descriptions.text_inputs.additional__few_on_stock"
        },
        {
          "type": "text",
          "id": "additional__out_of_stock",
          "label": "t:sections.blocks.inventory_status.additional_descriptions.text_inputs.additional__out_of_stock"
        },
        {
          "type": "text",
          "id": "additional__out_of_stock_continue_selling",
          "label": "t:sections.blocks.inventory_status.additional_descriptions.text_inputs.additional__out_of_stock_continue_selling"
        },
        {
          "type": "header",
          "content": "t:sections.headers.layout"
        },
        {
          "id": "margin_top",
          "type": "range",
          "label": "t:sections.layout.margin_top",
          "info": "t:sections.blocks.margin_info",
          "unit": "px",
          "default": 8,
          "min": 0,
          "max": 48,
          "step": 4
        }
      ]
    },
    {
      "type": "buy_buttons",
      "name": "t:sections.blocks.buy_buttons.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "t:sections.blocks.buy_buttons.show_dynamic_checkout.label",
          "info": "t:sections.blocks.buy_buttons.show_dynamic_checkout.info"
        },
        {
          "type": "checkbox",
          "id": "show_gift_card_recipient",
          "default": true,
          "label": "t:sections.blocks.buy_buttons.show_gift_card_recipient.label",
          "info": "t:sections.blocks.buy_buttons.show_gift_card_recipient.info"
        },
        {
