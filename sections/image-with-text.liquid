{%- liquid
  # Section index check
  if section.index == 1 and section.location == 'template'
    assign preload_media = true
  else
    assign preload_media = false
  endif

  # Blocks to variables
  assign full_width = section.settings.enable_full_width
  assign media_block = section.blocks | where: 'type', 'image' | first
  assign single_button_width_classes = ''

  capture sizes
    render 'img_sizes', full_width: full_width, ipr_mobile: 1, ipr_tablet: 2, ipr_desktop: 2
  endcapture

  if section.settings.sm_full_width_buttons
    assign single_button_width_classes = 'sm-btn--full'
  endif

  if section.settings.full_width_buttons
    assign single_button_width_classes = single_button_width_classes | append: ' sm-down-btn--full' | strip
  endif
-%}

<div
  id="{{ section.id }}"
  class="pt pb sm-pt sm-pb container sm-down-edge-to-edge{% if full_width %} full-width{% endif %} color-{{ section.settings.color_scheme }}"
  style="
    --pt: {{ section.settings.padding_top | append: 'px' }};
    --pb: {{ section.settings.padding_bottom | append: 'px' }};
    --sm-pt: {{ section.settings.md_padding_top | append: 'px' }};
    --sm-pb: {{ section.settings.md_padding_bottom | append: 'px' }};
  ">
  <div
    class="media-with-text grid grid-cols-1 sm-grid-cols-2 col-align-items-center col-justify-items-center">
    <div class="sm-br-img{% if section.settings.media_position == 'media_last' %} col-sm-order-2{% endif %}" {{ media_block.shopify_attributes }}>
      {%- if media_block.settings.media_link -%}<a class="media-link" href="{{ media_block.settings.media_link }}">{%- endif -%}
        {% if media_block.settings.media_type == 'video' or media_block.settings.media_type == 'mixed_media' and media_block.settings.video != blank -%}
            {%- render 'video-frame',
            video_default: media_block.settings.video,
            aspect_ratio: media_block.settings.media_aspect_ratio,
            autoplay: media_block.settings.video_autoplay,
            sizes: sizes,
            controls: media_block.settings.video_controls, -%}
        {% elsif media_block.settings.media_type == 'external_video' -%}
          {% assign scale_by_container = true %}
          {% if media_block.settings.video_controls or media_block.settings.media_aspect_ratio == 'natural' %}
            {% assign scale_by_container = false %}
          {% endif %}
          <div class="media {{ media_block.settings.media_aspect_ratio }}{% if scale_by_container %} external-video-container{% endif %}">
            {%- render 'external-video',
              default_external_video: media_block.settings.external_video_url,
              default_external_video_aspect_ratio: media_block.settings.external_video_aspect_ratio,
              controls: media_block.settings.video_controls,
              autoplay: media_block.settings.video_autoplay -%}
          </div>
        {% else -%}
          {%- render 'img',
            src: media_block.settings.image,
            aspect_ratio: media_block.settings.media_aspect_ratio,
            sizes: sizes,
            preload: preload_media -%}
        {%- endif %}
      {%- if media_block.settings.media_link -%}</a>{%- endif -%}
    </div>
    <div class="p-page pt-12 pb-24 sm-p-0 sm-pt-24 sm-pb-24 {{ section.settings.content_width }} {{ section.settings.mobile_alignment }} {{ section.settings.desktop_alignment }}">
      {% render 'content-blocks',
        blocks: section.blocks,
        use_text_container: true,
        single_button_classes: single_button_width_classes,
        color_scheme: section.settings.color_scheme %}
    </div>
  </div>
</div>

