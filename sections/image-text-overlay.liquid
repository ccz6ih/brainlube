{{ 'component-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign media_block = section.blocks | where: 'type', 'image' | first

  # Layout classes and button width classes
  assign section_layout_classes = 'height-' | append: section.settings.section_height | append: ' sm-height-' | append: section.settings.section_height_desktop
  assign single_button_width_classes = ''

  if section.settings.sm_full_width_buttons
    assign single_button_width_classes = 'sm-btn--full'
  endif

  if section.settings.full_width_buttons
    assign single_button_width_classes = single_button_width_classes | append: ' sm-down-btn--full' | strip
  endif

  # Lazyload
  assign lazyload = true
  if section.index == 1
    assign lazyload = false
  endif

  # Sizes string
  assign sizes_string = '100vw'
  unless section.settings.enable_full_width
    assign ideal_width = settings.content_ideal_width | append: 'px'
    assign sizes_string = '(min-width:' | append: settings.content_ideal_width | append: 'px) ' | append: ideal_width | append: ', 100vw'
  endunless
-%}

{% render 'hero-inline-styles', media_block: media_block %}

<div
  id="{{ section.id }}"
  class="container pt pb sm-pt sm-pb color-{{ section.settings.color_scheme }} {{ section_layout_classes }} {% if section.settings.enable_full_width %} edge-to-edge{% else %} sm-down-edge-to-edge{% endif %}"
  style="
    --pt: {{ section.settings.padding_top | append: 'px' }};
    --pb: {{ section.settings.padding_bottom | append: 'px' }};
    --sm-pt: {{ section.settings.md_padding_top | append: 'px' }};
    --sm-pb: {{ section.settings.md_padding_bottom | append: 'px' }};
  ">
  <div class="hero{% unless section.settings.enable_full_width %} sm-br-img{% endunless %}">
    <div class="hero__media{% if media_block.settings.media_type == 'external_video' %} external-video-container{% endif %}{% unless section.settings.enable_full_width %} sm-br-img{% endunless %}" {{ media_block.shopify_attributes }}>
    {%- case media_block.settings.media_type -%}
      {%- when 'video' -%}
        {%- render 'video-frame',
          video_default: media_block.settings.cdn_video,
          video_mobile: media_block.settings.cdn_video_mobile
        -%}
      {%- when 'mixed_media' -%}
        {% if media_block.settings.cdn_video != blank %}
          {%- render 'video-frame', video_default: media_block.settings.cdn_video, video_mobile: media_block.settings.cdn_video_mobile -%}
        {% else %}
          {%- render 'img', lazyload: lazyload, wrapped: false, src: media_block.settings.image, src_mobile: media_block.settings.image_mobile, sizes: sizes_string, placeholder: 'lifestyle-2' -%}
        {% endif %}
      {%- when 'external_video' -%}
        {% render 'external-video',
          default_external_video: media_block.settings.external_video_url,
          mobile_external_video: media_block.settings.external_video_url_mobile,
          default_external_video_aspect_ratio: media_block.settings.external_video_url_aspect_ratio,
          mobile_external_video_aspect_ratio: media_block.settings.external_video_url_mobile_aspect_ratio,
          hide_branding: media_block.settings.external_video_hide_branding
        -%}
      {%- else -%}
        {%- render 'img',
          lazyload: lazyload,
          wrapped: false,
          src: media_block.settings.image,
          src_mobile: media_block.settings.image_mobile,
          sizes: sizes_string,
          placeholder: 'lifestyle-2'
        -%}
    {%- endcase -%}
    </div>
    <div class="hero__text">
      <div class="hero__text-container {{ section.settings.content_align_mobile }} {{ section.settings.content_align_desktop }}">
        <div class="p-24 sm-p-40 br-img {{ section.settings.content_width }} color-{{ section.settings.color_scheme_content }}" style="width:100%;">
          {% render 'content-blocks',
            blocks: section.blocks,
            use_text_container: true,
            single_button_classes: single_button_width_classes,
            color_scheme: section.settings.color_scheme_content %}
        </div>
      </div>
    </div>
  </div>
</div>

