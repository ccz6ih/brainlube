{%- liquid
  # Section index check
  if section.index == 1 and section.location == 'template'
    assign preload_media = true
  else
    assign preload_media = false
  endif

  # Blocks to variables
  assign row_blocks = section.blocks | where: 'type', 'row'

  # Variables
  assign ipr_desktop = 1
  assign ipr_tablet = 1
  assign ipr_mobile = 1
  assign slider_mobile = false
  assign slider_desktop = false
  assign slider_items_count = row_blocks | size
  assign single_button_width_classes = section.settings.button_size_multiplier | append: ' ' | append: section.settings.button_sm_size_multiplier
  assign btn_group_width_classes = 'sm-down-width-auto sm-width-auto'
  assign full_width = section.settings.enable_full_width

  if section.settings.layout_mobile contains 'slide'
    assign slider_mobile = true
  endif
  if section.settings.layout_desktop == 'slide'
    assign slider_desktop = true
  endif

  # Button width classes
  if section.settings.sm_full_width_buttons
    assign single_button_width_classes = single_button_width_classes | append:' sm-btn--full' | strip
    assign btn_group_width_classes = btn_group_width_classes | remove: 'sm-width-auto' | strip
  endif

  if section.settings.full_width_buttons
    assign single_button_width_classes = single_button_width_classes | append: ' sm-down-btn--full' | strip
    assign btn_group_width_classes = btn_group_width_classes | remove: 'sm-down-width-auto' | strip

  endif
  capture sizes
    render 'img_sizes', full_width: full_width, ipr_mobile: 1, ipr_tablet: 2, ipr_desktop: 2
  endcapture

-%}

{{ 'section-image-with-text.css' | asset_url |  stylesheet_tag  }}

<div
  id="{{ section.id }}"
  class="container section-spacing sm-down-edge-to-edge color-{{ section.settings.color_scheme }} pt pb sm-pt sm-pb {% if full_width %} sm-edge-to-edge sm-p-page{% endif %}"
  style="
    --pt: {{ section.settings.padding_top | append: 'px' }};
    --pb: {{ section.settings.padding_bottom | append: 'px' }};
    --sm-pt: {{ section.settings.md_padding_top | append: 'px' }};
    --sm-pb: {{ section.settings.md_padding_bottom | append: 'px' }};
  ">

  <gridy-slider
    id="slider-{{ section.id }}"
    class="gridy-slider"
    data-mobile-enabled="{{ slider_mobile }}"
    data-tablet-enabled="{{ slider_desktop }}"
    data-desktop-enabled="{{ slider_desktop }}"
    data-ipr-desktop="{{ ipr_desktop }}"
    data-ipr-tablet="{{ ipr_tablet }}"
    data-ipr-mobile="{{ ipr_mobile }}"
    data-arrows="true"
    data-progress-bar="true"
    data-autoplay="{{ section.settings.autoplay}}"
    data-autoplay-delay="{{ section.settings.autoplay_speed | times: 1000 }}">
    <div class="grid gridy-track scrollbar--hide grid-cols-{{ ipr_mobile }} sm-grid-cols-{{ ipr_tablet }} md-grid-cols-{{ ipr_desktop }}">
      {% for block in row_blocks %}
        {%- liquid
          # Text column width
          assign md_text_col_width = 12 | minus: section.settings.media_width
          assign media_position = section.settings.media_position
          assign forloop_modulo = forloop.index0 | modulo: 2

          if forloop_modulo == 0 and section.settings.even_row_flip
            if section.settings.media_position == 'media_first'
              assign media_position = 'media_last'
            else
              assign media_position = 'media_first'
            endif
          endif
        -%}
        <div class="grid {{ block.settings.vertical_position }}" {{ block.shopify_attributes }}>
          <div class="col-12 col-sm-6 col-md-{{ section.settings.media_width }} sm-br-img{% if media_position == 'media_last' %} col-sm-order-2{% endif %} {% if block.settings.video %} {{ section.settings.media_aspect_ratio }} {% endif %}">
            {%- if block.settings.media_link -%}<a class="media-link" href="{{ block.settings.media_link }}">{%- endif -%}
            {% if block.settings.media_type == 'video' or block.settings.media_type == 'mixed_media' and block.settings.video != blank -%}
                {%- render 'video-frame',
                video_default: block.settings.video,
                aspect_ratio: section.settings.media_aspect_ratio,
                autoplay: block.settings.video_autoplay,
                sizes: sizes,
                controls: block.settings.video_controls -%}
            {% elsif block.settings.media_type == 'external_video' -%}
              {% assign scale_by_container = true %}
              {% if block.settings.video_controls or section.settings.media_aspect_ratio == 'natural' %}
                {% assign scale_by_container = false %}
              {% endif %}
              <div class="media {{ section.settings.media_aspect_ratio }}{% if scale_by_container %} external-video-container{% endif %}">
                {%- render 'external-video',
                  default_external_video: block.settings.external_video_url,
                  default_external_video_aspect_ratio: block.settings.external_video_aspect_ratio,
                  controls: block.settings.video_controls,
                  autoplay: block.settings.video_autoplay -%}
              </div>
            {% else -%}
              {%- render 'img',
                src: block.settings.image,
                aspect_ratio: section.settings.media_aspect_ratio,
                sizes: sizes,
                preload: preload_media -%}
            {%- endif %}
            {%- if block.settings.media_link -%}</a>{%- endif -%}
          </div>
          <div class="col-12 col-sm-6 col-md-{{ md_text_col_width }} p-page sm-p-0">
            <div class="multicolumn-item standard-items-spacing {{ section.settings.content_width }} text-align-{{ block.settings.text_alignment }} {{ block.settings.horizontal_position }}" {{ block.shopify_attributes }}>
              {% if block.settings.title -%}
                <h2 class="blocks-title {{ section.settings.heading_size_multiplier }} {{ section.settings.heading_sm_size_multiplier }}">{{ block.settings.title | replace: '[br]', '<br>' }}</h2>
              {%- endif %}
              {% if block.settings.text -%}
                <div class="blocks-rte rte {{ section.settings.text_size_multiplier }} {{ section.settings.text_sm_size_multiplier }}">{{ block.settings.text }}</div>
              {%- endif %}
              {% if block.settings.button_label != blank and block.settings.button_link != blank or block.settings.button_2_label != blank and block.settings.button_2_link != blank -%}
                <div class="btn-group mt sm-mt {{ btn_group_width_classes }}">
                  {% if block.settings.button_label != blank and block.settings.button_link != blank -%}
                    {%- render 'button',
                      label: block.settings.button_label,
                      link: block.settings.button_link,
                      style: block.settings.button_style,
                      classes: single_button_width_classes -%}
                  {%- endif %}
                  {% if block.settings.button_2_label != blank and block.settings.button_2_link != blank -%}
                    {%- render 'button',
                      label: block.settings.button_2_label,
                      link: block.settings.button_2_link,
                      style: block.settings.button_2_style,
                      classes: single_button_width_classes -%}
                  {%- endif %}
                </div>
              {%- endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

 {%- liquid
      assign arrows_class = 'sm-on-edge'
      if slider_items_count <= ipr_desktop
        assign arrows_class = arrows_class | append: ' md-hide'
      endif
      if slider_items_count <= ipr_tablet
        assign arrows_class = arrows_class | append: ' sm-to-md-hide'
      endif
      if slider_items_count <= ipr_mobile
        assign arrows_class = arrows_class | append: ' sm-down-hide'
      endif

    -%}
      {% render 'gridy-arrows',
      class: arrows_class
      %}
  </gridy-slider>
</div>

